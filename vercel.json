{
  "version": 2,
  "builds": [
    { "src": "/api/*.js", "use": "@vercel/node" },
    { "src": "/public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/cats", "dest": "/api/cats.js" },
    { "src": "/api/sightings", "dest": "/api/sightings.js" },
    { "src": "/api/feedings", "dest": "/api/feedings.js" },
    { "src": "/api/stats", "dest": "/api/stats.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
